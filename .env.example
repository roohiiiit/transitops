# TransitOps Environment Variables

# (Required for AI Bill Scanning) Get your API key from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here

# (Optional) Override the default secret key used for signing JWTs
# SECRET_KEY=your_secure_random_string_here

# (Optional) Comma separated list of allowed origins for CORS. Default allows frontend running on 8080.
# CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
